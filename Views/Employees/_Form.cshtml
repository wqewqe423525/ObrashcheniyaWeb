@model EmployeeFormModel
@{
    bool isEdit = (bool)(ViewData["IsEdit"] ?? false);
}
<div class="row g-3">
    <div class="col-md-8">
        <label asp-for="FullName" class="form-label"></label>
        <input asp-for="FullName" class="form-control" placeholder="Фамилия Имя Отчество" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Role" class="form-label"></label>
        <select asp-for="Role" asp-items="ViewBag.Roles" class="form-select"></select>
        <span asp-validation-for="Role" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Position" class="form-label"></label>
        <input asp-for="Position" class="form-control" placeholder="Например: Специалист" />
        <span asp-validation-for="Position" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Login" class="form-label"></label>
        <input asp-for="Login" class="form-control" autocomplete="off" />
        <span asp-validation-for="Login" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" class="form-control" autocomplete="new-password"
               placeholder="@(isEdit ? "Оставьте пустым, чтобы не менять" : "Задайте пароль")" />
        <span asp-validation-for="Password" class="text-danger"></span>
        @if (isEdit)
        {
            <div class="field-hint">Заполняйте только при смене пароля сотрудника.</div>
        }
    </div>
</div>
