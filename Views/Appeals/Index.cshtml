@model AppealFilterViewModel
@{
    ViewData["Title"] = "Обращения";
    bool isAdmin = User.IsInRole(Roles.Admin);
    bool hasFilter = !string.IsNullOrWhiteSpace(Model.Search) || Model.StatusId.HasValue
        || Model.RequestTypeId.HasValue || Model.DateFrom.HasValue || Model.DateTo.HasValue;
}

<div class="page-head">
    <div>
        <p class="eyebrow">Реестр</p>
        <h1>Обращения граждан</h1>
        <p class="lead-sub">Найдено записей: @Model.Appeals.Count</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Новое обращение
    </a>
</div>

<!-- Панель фильтров и поиска -->
<form asp-action="Index" method="get" class="filter-bar mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-12 col-lg-4">
            <label asp-for="Search" class="form-label"></label>
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                <input asp-for="Search" class="form-control" placeholder="Фамилия, имя или отчество" />
            </div>
        </div>
        <div class="col-6 col-lg-2">
            <label asp-for="StatusId" class="form-label"></label>
            <select asp-for="StatusId" asp-items="Model.Statuses" class="form-select">
                <option value="">Все статусы</option>
            </select>
        </div>
        <div class="col-6 col-lg-2">
            <label asp-for="RequestTypeId" class="form-label"></label>
            <select asp-for="RequestTypeId" asp-items="Model.RequestTypes" class="form-select">
                <option value="">Все типы</option>
            </select>
        </div>
        <div class="col-6 col-lg-2">
            <label asp-for="DateFrom" class="form-label"></label>
            <input asp-for="DateFrom" class="form-control" type="date" />
        </div>
        <div class="col-6 col-lg-2">
            <label asp-for="DateTo" class="form-label"></label>
            <input asp-for="DateTo" class="form-control" type="date" />
        </div>
    </div>
    <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-funnel me-1"></i>Применить
        </button>
        @if (hasFilter)
        {
            <a asp-action="Index" class="btn btn-soft">
                <i class="bi bi-x-lg me-1"></i>Сбросить
            </a>
        }
    </div>
</form>

<!-- Таблица обращений -->
<div class="card table-card">
    @if (Model.Appeals.Count == 0)
    {
        <div class="empty-state">
            <div class="icon"><i class="bi bi-inbox"></i></div>
            <h5 class="mb-1">Обращения не найдены</h5>
            <p class="mb-0">Измените условия фильтра или зарегистрируйте новое обращение.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>№</th>
                        <th>Гражданин</th>
                        <th>Тип обращения</th>
                        <th>Дата</th>
                        <th>Статус</th>
                        <th>Ответственный</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.Appeals)
                    {
                        <tr>
                            <td class="fw-bold text-muted-2">#@a.Id</td>
                            <td>
                                <div class="fw-semibold">@(a.Citizen?.ShortName ?? "—")</div>
                                @if (!string.IsNullOrWhiteSpace(a.Citizen?.Phone))
                                {
                                    <div class="text-muted-2" style="font-size:.82rem;">
                                        <i class="bi bi-telephone me-1"></i>@a.Citizen!.Phone
                                    </div>
                                }
                            </td>
                            <td>@(a.RequestType?.Name ?? "—")</td>
                            <td class="text-nowrap">@a.SubmissionDate.ToString("dd.MM.yyyy")</td>
                            <td><partial name="_StatusBadge" model="a.Status" /></td>
                            <td class="text-muted-2" style="font-size:.9rem;">@(a.Employee?.FullName ?? "—")</td>
                            <td class="text-end text-nowrap">
                                <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-soft" title="Просмотр">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (isAdmin)
                                {
                                    <a asp-action="Process" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary" title="Обработать">
                                        <i class="bi bi-gear"></i>
                                    </a>
                                    <a asp-action="ChangeStatus" asp-route-id="@a.Id" class="btn btn-sm btn-soft" title="Изменить статус">
                                        <i class="bi bi-flag"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@a.Id" class="btn btn-sm btn-soft text-danger" title="Удалить">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
