@model RequestType
@{
    ViewData["Title"] = "Новый тип обращения";
}

<div class="page-head">
    <div><p class="eyebrow">Справочник типов</p><h1>Новый тип обращения</h1></div>
    <a asp-action="Index" class="btn btn-soft"><i class="bi bi-arrow-left me-1"></i>К списку</a>
</div>

<div class="row"><div class="col-lg-7">
    <div class="card"><div class="card-body">
        <form asp-action="Create" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Например: Поиск работы" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Краткое описание категории"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Сохранить</button>
                <a asp-action="Index" class="btn btn-soft">Отмена</a>
            </div>
        </form>
    </div></div>
</div></div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
