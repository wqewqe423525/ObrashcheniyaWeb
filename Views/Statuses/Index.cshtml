@model List<Status>
@{
    ViewData["Title"] = "Статусы обращений";
    var counts = ViewBag.AppealCounts as Dictionary<int, int> ?? new();
}

<div class="page-head">
    <div>
        <p class="eyebrow">Справочник</p>
        <h1>Статусы обращений</h1>
        <p class="lead-sub">Этапы жизненного цикла обращения</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Добавить статус</a>
</div>

<div class="card table-card">
    @if (Model.Count == 0)
    {
        <div class="empty-state"><div class="icon"><i class="bi bi-flag"></i></div><h5 class="mb-1">Статусы не заданы</h5></div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr><th>#</th><th>Статус</th><th>Обращений</th><th class="text-end">Действия</th></tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        var n = counts.TryGetValue(s.Id, out var c) ? c : 0;
                        <tr>
                            <td class="fw-bold text-muted-2">@s.Id</td>
                            <td><partial name="_StatusBadge" model="s" /></td>
                            <td><span class="role-badge role-user">@n</span></td>
                            <td class="text-end text-nowrap">
                                <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary" title="Изменить"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Delete" asp-route-id="@s.Id" class="btn btn-sm btn-soft text-danger" title="Удалить"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
