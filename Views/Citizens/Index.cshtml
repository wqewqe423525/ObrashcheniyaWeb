@model List<Citizen>
@{
    ViewData["Title"] = "Граждане";
    string? search = ViewBag.Search as string;
}

<div class="page-head">
    <div>
        <p class="eyebrow">Справочник</p>
        <h1>Граждане</h1>
        <p class="lead-sub">Всего в базе: @Model.Count</p>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-person-plus me-1"></i>Добавить гражданина</a>
</div>

<form asp-action="Index" method="get" class="filter-bar mb-4">
    <div class="row g-2 align-items-end">
        <div class="col">
            <label class="form-label" for="search">Поиск по ФИО или телефону</label>
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                <input id="search" name="search" value="@search" class="form-control" placeholder="Введите запрос" />
            </div>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i>Найти</button>
        </div>
        @if (!string.IsNullOrWhiteSpace(search))
        {
            <div class="col-auto"><a asp-action="Index" class="btn btn-soft">Сбросить</a></div>
        }
    </div>
</form>

<div class="card table-card">
    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <div class="icon"><i class="bi bi-people"></i></div>
            <h5 class="mb-1">Граждане не найдены</h5>
            <p class="mb-0">Измените запрос или добавьте нового гражданина.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>ФИО</th>
                        <th>Дата рождения</th>
                        <th>Телефон</th>
                        <th>Email</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@c.FullName</td>
                            <td>@(c.BirthDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                            <td>@(string.IsNullOrWhiteSpace(c.Phone) ? "—" : c.Phone)</td>
                            <td>@(string.IsNullOrWhiteSpace(c.Email) ? "—" : c.Email)</td>
                            <td class="text-end text-nowrap">
                                <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-soft" title="Просмотр"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary" title="Изменить"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Delete" asp-route-id="@c.Id" class="btn btn-sm btn-soft text-danger" title="Удалить"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
