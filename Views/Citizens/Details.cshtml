@model Citizen
@{
    ViewData["Title"] = Model.FullName;
    var appeals = Model.Appeals.OrderByDescending(a => a.SubmissionDate).ToList();
}

<div class="page-head">
    <div>
        <p class="eyebrow">Карточка гражданина</p>
        <h1>@Model.FullName</h1>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-soft"><i class="bi bi-arrow-left me-1"></i>К списку</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil me-1"></i>Изменить</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header"><i class="bi bi-person-vcard me-2"></i>Личные данные</div>
            <div class="card-body">
                <dl class="detail-list mb-0">
                    <dt>Дата рождения</dt>
                    <dd>@(Model.BirthDate?.ToString("dd.MM.yyyy") ?? "—")</dd>
                    <dt>Телефон</dt>
                    <dd>@(string.IsNullOrWhiteSpace(Model.Phone) ? "—" : Model.Phone)</dd>
                    <dt>Email</dt>
                    <dd>@(string.IsNullOrWhiteSpace(Model.Email) ? "—" : Model.Email)</dd>
                    <dt>Адрес</dt>
                    <dd class="mb-0">@(string.IsNullOrWhiteSpace(Model.Address) ? "—" : Model.Address)</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card table-card">
            <div class="card-header"><i class="bi bi-inbox me-2"></i>Обращения гражданина (@appeals.Count)</div>
            @if (appeals.Count == 0)
            {
                <div class="empty-state py-4"><div class="icon"><i class="bi bi-inbox"></i></div>Обращений нет</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr><th>№</th><th>Тип</th><th>Дата</th><th>Статус</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var a in appeals)
                            {
                                <tr>
                                    <td class="fw-bold text-muted-2">#@a.Id</td>
                                    <td>@(a.RequestType?.Name ?? "—")</td>
                                    <td class="text-nowrap">@a.SubmissionDate.ToString("dd.MM.yyyy")</td>
                                    <td><partial name="_StatusBadge" model="a.Status" /></td>
                                    <td class="text-end">
                                        <a asp-controller="Appeals" asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-soft"><i class="bi bi-eye"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
