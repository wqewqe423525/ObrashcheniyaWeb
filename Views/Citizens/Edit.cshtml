@model Citizen
@{
    ViewData["Title"] = "Изменение данных гражданина";
}

<div class="page-head">
    <div>
        <p class="eyebrow">Справочник граждан</p>
        <h1>Изменение: @Model.ShortName</h1>
    </div>
    <a asp-action="Index" class="btn btn-soft"><i class="bi bi-arrow-left me-1"></i>К списку</a>
</div>

<div class="row">
    <div class="col-lg-9">
        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate>
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <partial name="_Form" model="Model" />
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Сохранить изменения</button>
                        <a asp-action="Index" class="btn btn-soft">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
