@{
    ViewData["Title"] = "Доступ запрещён";
    ViewData["FullScreen"] = true;
}

<div class="auth-wrap">
    <div class="auth-card fade-in-up" style="max-width:480px;">
        <div class="auth-head" style="background:linear-gradient(160deg,#a23b34 0%,#7d2a24 100%);border-bottom-color:var(--accent);">
            <div class="emblem" style="border-color:var(--accent);"><i class="bi bi-shield-lock" style="font-size:1.7rem;"></i></div>
            <h1>Доступ запрещён</h1>
            <p>Недостаточно прав для просмотра раздела</p>
        </div>
        <div class="auth-body text-center">
            <p class="text-muted-2 mb-4">
                Эта страница доступна только пользователям с ролью «администратор».
                Если вы считаете, что это ошибка, обратитесь к администратору системы.
            </p>
            <div class="d-flex justify-content-center gap-2">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-house me-1"></i>На главную
                </a>
                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                    <button type="submit" class="btn btn-soft">
                        <i class="bi bi-box-arrow-right me-1"></i>Сменить пользователя
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
