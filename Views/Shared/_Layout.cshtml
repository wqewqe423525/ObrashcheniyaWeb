@using System.Security.Claims
@{
    var fullScreen = ViewData["FullScreen"] as bool? ?? false;
    string? ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
    bool IsAdmin = User?.IsInRole(Roles.Admin) ?? false;
    string displayName = User?.FindFirst("FullName")?.Value
        ?? User?.Identity?.Name
        ?? "Гость";
    string roleName = User?.FindFirst(ClaimTypes.Role)?.Value ?? string.Empty;
    string initials = string.Concat(
        displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2).Select(p => char.ToUpper(p[0])));
    bool authed = User?.Identity?.IsAuthenticated ?? false;

    string NavActive(string controller) =>
        string.Equals(ctrl, controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Система учёта обращений") — КТСЗН г. Ставрополь</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Golos+Text:wght@400;500;600;700&family=Spectral:wght@500;600;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@if (!fullScreen)
{
    <nav class="navbar navbar-expand-lg app-navbar">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-emblem"><i class="bi bi-bank2"></i></span>
                <span>
                    Учёт обращений
                    <span class="d-block brand-sub">Комитет труда и соцзащиты</span>
                </span>
            </a>
            @if (authed)
            {
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link @NavActive("Home")" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i>Дашборд
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @NavActive("Appeals")" asp-controller="Appeals" asp-action="Index">
                                <i class="bi bi-inbox me-1"></i>Обращения
                            </a>
                        </li>
                        @if (IsAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Citizens")" asp-controller="Citizens" asp-action="Index">
                                    <i class="bi bi-people me-1"></i>Граждане
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @NavActive("RequestTypes")" asp-controller="RequestTypes" asp-action="Index">
                                    <i class="bi bi-tags me-1"></i>Типы обращений
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Statuses")" asp-controller="Statuses" asp-action="Index">
                                    <i class="bi bi-flag me-1"></i>Статусы
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Employees")" asp-controller="Employees" asp-action="Index">
                                    <i class="bi bi-person-badge me-1"></i>Сотрудники
                                </a>
                            </li>
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-3">
                        <div class="user-chip">
                            <span class="avatar">@(string.IsNullOrEmpty(initials) ? "?" : initials)</span>
                            <span class="d-none d-sm-block">
                                @displayName
                                <span class="d-block role-tag">@roleName</span>
                            </span>
                        </div>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            <button type="submit" class="btn btn-sm btn-soft" title="Выйти из системы">
                                <i class="bi bi-box-arrow-right"></i>
                                <span class="d-none d-md-inline ms-1">Выход</span>
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </nav>
}

@if (fullScreen)
{
    @RenderBody()
}
else
{
    <main class="app-main">
        <div class="container">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show d-flex align-items-center" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <div>@TempData["Success"]</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div>@TempData["Error"]</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }
            <div class="fade-in-up">
                @RenderBody()
            </div>
        </div>
    </main>

    <footer class="app-footer">
        <div class="container d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div>
                <i class="bi bi-bank2 me-1"></i>
                Система учёта обращений граждан &middot; Комитет труда и социальной защиты населения, г. Ставрополь
            </div>
            <div class="text-white-50">© @DateTime.Now.Year &middot; ASP.NET Core 8 MVC</div>
        </div>
    </footer>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
